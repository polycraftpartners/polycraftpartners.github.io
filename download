import { useMemo, useState } from 'react'
import { useNavigate } from 'react-router-dom'
import ProgressBar from '../components/ProgressBar'
import QuestionCard from '../components/QuestionCard'
import { PROFILE_QUESTIONS, DIAGNOSTIC_QUESTIONS } from '../lib/questions'
import { submitAssessment } from '../lib/submission'
import type { AssessmentAnswers, ContactDetails } from '../lib/types'

type StepType = 'profile' | 'diagnostic' | 'open' | 'contact'

interface FlowStep {
  type: StepType
  index: number // index within its own array, used for profile/diagnostic
}

const TOTAL_STEPS = PROFILE_QUESTIONS.length + DIAGNOSTIC_QUESTIONS.length + 2 // + open + contact

export default function AssessmentPage() {
  const navigate = useNavigate()
  const [stepNumber, setStepNumber] = useState(0)
  const [submitting, setSubmitting] = useState(false)
  const [submitError, setSubmitError] = useState<string | null>(null)

  const [profileAnswers, setProfileAnswers] = useState<Record<string, string>>({})
  const [diagnosticAnswers, setDiagnosticAnswers] = useState<Record<string, 1 | 2 | 3 | 4>>({})
  const [openResponse, setOpenResponse] = useState('')
  const [contact, setContact] = useState<ContactDetails>({
    name: '',
    company: '',
    email: '',
    country: '',
    consent_data: false,
    consent_email: false
  })

  const flow: FlowStep[] = useMemo(() => {
    const steps: FlowStep[] = []
    PROFILE_QUESTIONS.forEach((_, i) => steps.push({ type: 'profile', index: i }))
    DIAGNOSTIC_QUESTIONS.forEach((_, i) => steps.push({ type: 'diagnostic', index: i }))
    steps.push({ type: 'open', index: 0 })
    steps.push({ type: 'contact', index: 0 })
    return steps
  }, [])

  const currentStep = flow[stepNumber]

  function goNext() {
    if (stepNumber < flow.length - 1) {
      setStepNumber(stepNumber + 1)
    }
  }

  function goBack() {
    if (stepNumber > 0) {
      setStepNumber(stepNumber - 1)
    }
  }

  function handleProfileSelect(questionId: string, value: string) {
    setProfileAnswers((prev) => ({ ...prev, [questionId]: value }))
    setTimeout(goNext, 200)
  }

  function handleDiagnosticSelect(questionId: string, value: 1 | 2 | 3 | 4) {
    setDiagnosticAnswers((prev) => ({ ...prev, [questionId]: value }))
    setTimeout(goNext, 200)
  }

  async function handleFinalSubmit() {
    if (!contact.consent_data) {
      setSubmitError('Please confirm you agree to your data being stored for this research.')
      return
    }
    if (!contact.name || !contact.company || !contact.email || !contact.country) {
      setSubmitError('Please complete all fields before submitting.')
      return
    }

    setSubmitting(true)
    setSubmitError(null)

    const answers: AssessmentAnswers = {
      industry: profileAnswers.industry,
      company_size: profileAnswers.company_size,
      growth_objective: profileAnswers.growth_objective,
      founder_involvement: profileAnswers.founder_involvement,
      diagnostic: diagnosticAnswers,
      open_response: openResponse
    }

    const result = await submitAssessment(answers, contact)

    setSubmitting(false)

    if (!result.success) {
      setSubmitError(
        result.error ?? 'Something went wrong submitting your assessment. Please try again.'
      )
      return
    }

    navigate('/thank-you')
  }

  return (
    <div className="min-h-screen flex flex-col">
      <div className="px-6 py-6 md:px-12 max-w-2xl mx-auto w-full">
        <ProgressBar current={stepNumber + 1} total={TOTAL_STEPS} />
      </div>

      <main className="flex-1 flex items-start px-6 md:px-12">
        <div className="max-w-2xl mx-auto w-full py-8">
          {currentStep.type === 'profile' && (
            <QuestionCard
              questionNumber={stepNumber + 1}
              text={PROFILE_QUESTIONS[currentStep.index].text}
              options={PROFILE_QUESTIONS[currentStep.index].options.map((o) => ({
                label: o.label,
                value: o.value
              }))}
              selectedValue={profileAnswers[PROFILE_QUESTIONS[currentStep.index].id] ?? null}
              onSelect={(value) =>
                handleProfileSelect(PROFILE_QUESTIONS[currentStep.index].id, String(value))
              }
            />
          )}

          {currentStep.type === 'diagnostic' && (
            <QuestionCard
              questionNumber={stepNumber + 1}
              text={DIAGNOSTIC_QUESTIONS[currentStep.index].text}
              options={DIAGNOSTIC_QUESTIONS[currentStep.index].options.map((o) => ({
                label: o.label,
                value: o.value
              }))}
              selectedValue={
                diagnosticAnswers[DIAGNOSTIC_QUESTIONS[currentStep.index].id] ?? null
              }
              onSelect={(value) =>
                handleDiagnosticSelect(
                  DIAGNOSTIC_QUESTIONS[currentStep.index].id,
                  value as 1 | 2 | 3 | 4
                )
              }
            />
          )}

          {currentStep.type === 'open' && (
            <div className="fade-up">
              <h2 className="font-display text-2xl md:text-3xl font-bold text-textPrimary leading-tight mb-3">
                What is the single most frustrating growth-related problem you face today that
                you feel should already be solved?
              </h2>
              <p className="text-textMuted text-sm mb-6">
                Optional, but this is often the most valuable answer you can give us.
              </p>
              <textarea
                value={openResponse}
                onChange={(e) => setOpenResponse(e.target.value)}
                rows={6}
                placeholder="Take your time. There is no right answer."
                className="w-full px-5 py-4 rounded-lg border border-border bg-surface text-textPrimary placeholder:text-textMuted focus:outline-none focus:border-gold transition-colors resize-none"
              />
              <button
                type="button"
                onClick={goNext}
                className="mt-6 px-8 py-3 bg-gold text-bg font-display font-bold rounded-lg hover:bg-goldDark transition-colors duration-150"
              >
                Continue
              </button>
            </div>
          )}

          {currentStep.type === 'contact' && (
            <div className="fade-up">
              <h2 className="font-display text-2xl md:text-3xl font-bold text-textPrimary leading-tight mb-3">
                Almost done. Where should we send your report?
              </h2>
              <p className="text-textMuted text-sm mb-6">
                Your individual responses are never shared. See our privacy approach below.
              </p>

              <div className="space-y-4">
                <input
                  type="text"
                  placeholder="Full name"
                  value={contact.name}
                  onChange={(e) => setContact({ ...contact, name: e.target.value })}
                  className="w-full px-5 py-4 rounded-lg border border-border bg-surface text-textPrimary placeholder:text-textMuted focus:outline-none focus:border-gold transition-colors"
                />
                <input
                  type="text"
                  placeholder="Company"
                  value={contact.company}
                  onChange={(e) => setContact({ ...contact, company: e.target.value })}
                  className="w-full px-5 py-4 rounded-lg border border-border bg-surface text-textPrimary placeholder:text-textMuted focus:outline-none focus:border-gold transition-colors"
                />
                <input
                  type="email"
                  placeholder="Email"
                  value={contact.email}
                  onChange={(e) => setContact({ ...contact, email: e.target.value })}
                  className="w-full px-5 py-4 rounded-lg border border-border bg-surface text-textPrimary placeholder:text-textMuted focus:outline-none focus:border-gold transition-colors"
                />
                <input
                  type="text"
                  placeholder="Country"
                  value={contact.country}
                  onChange={(e) => setContact({ ...contact, country: e.target.value })}
                  className="w-full px-5 py-4 rounded-lg border border-border bg-surface text-textPrimary placeholder:text-textMuted focus:outline-none focus:border-gold transition-colors"
                />

                <label className="flex items-start gap-3 pt-2 cursor-pointer">
                  <input
                    type="checkbox"
                    checked={contact.consent_data}
                    onChange={(e) => setContact({ ...contact, consent_data: e.target.checked })}
                    className="mt-1 w-4 h-4 accent-gold"
                  />
                  <span className="text-sm text-textSecondary">
                    I agree to my responses being stored and used to produce the Founder Growth
                    Benchmark research.
                  </span>
                </label>

                <label className="flex items-start gap-3 cursor-pointer">
                  <input
                    type="checkbox"
                    checked={contact.consent_email}
                    onChange={(e) => setContact({ ...contact, consent_email: e.target.checked })}
                    className="mt-1 w-4 h-4 accent-gold"
                  />
                  <span className="text-sm text-textSecondary">
                    I agree to be contacted by PolyCraft Consulting with my personalised report
                    and related updates.
                  </span>
                </label>
              </div>

              {submitError && (
                <p className="text-critical text-sm mt-4">{submitError}</p>
              )}

              <button
                type="button"
                onClick={handleFinalSubmit}
                disabled={submitting}
                className="mt-6 px-8 py-4 bg-gold text-bg font-display font-bold rounded-lg hover:bg-goldDark transition-colors duration-150 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                {submitting ? 'Submitting...' : 'Submit my assessment'}
              </button>
            </div>
          )}

          {stepNumber > 0 && currentStep.type !== 'contact' && (
            <button
              type="button"
              onClick={goBack}
              className="mt-8 text-textMuted text-sm hover:text-textSecondary transition-colors"
            >
              Back
            </button>
          )}
        </div>
      </main>
    </div>
  )
}
